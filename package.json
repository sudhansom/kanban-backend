{
  "name": "kanban-api",
  "version": "1.0.0",
  "description": "Kanban board API with Express, TypeScript, and MongoDB",
  "main": "dist/server.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "tsc && node dist/server.js",
    "watch": "tsc --watch",
    "start-dev": "nodemon --watch src --ext ts --exec tsx src/server.ts",
    "dev": "npm-run-all --parallel watch start-dev",
    "seed": "tsx scripts/seed.ts"
  },
  "keywords": ["kanban", "express", "mongodb"],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "chalk": "^5.6.2",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.5.0",
    "npm-run-all": "^4.1.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "nodemon": "^3.1.14",
    "tsx": "^4.19.3",
    "typescript": "^6.0.3"
  }
}
